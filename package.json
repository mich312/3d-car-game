{
  "name": "nitro-rumble",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Nitro Rumble — a 3D multiplayer arcade car game built with React Three Fiber",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "predev": "node scripts/preflight.js",
    "dev": "concurrently -k \"node server/index.js --port 5174\" \"vite\"",
    "prebuild": "node scripts/preflight.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "npm run build && node server/index.js"
  },
  "dependencies": {
    "@react-three/drei": "^10.3.0",
    "@react-three/fiber": "^9.1.0",
    "@react-three/postprocessing": "^3.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.177.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "vite": "^6.3.5"
  }
}
